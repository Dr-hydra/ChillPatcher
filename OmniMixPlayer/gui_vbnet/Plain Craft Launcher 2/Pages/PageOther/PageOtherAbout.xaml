<local:MyPageRight
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PCL"
    x:Class="PageOtherAbout"
    PanScroll="PanBack"
    RenderOptions.BitmapScalingMode="LowQuality">
    <local:MyScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          x:Name="PanBack">
        <StackPanel x:Name="PanMain"
                    Margin="25,10"
                    Grid.IsSharedSizeScope="True">
            <local:MyCard Margin="0,15" Title="关于">
                <StackPanel Margin="25,40,25,20">
                    <TextBlock Text="OmniMix Player"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ColorBrush3}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="面向游戏场景的音乐聚合与播放控制前端。"
                               FontSize="13"
                               Foreground="{DynamicResource ColorBrush2}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />
                    <TextBlock Text="它负责连接本机后端，展示播放状态、队列、曲库、音乐模块、游戏集成和均衡器设置；同时尽量保持与现有 OmniMix 后端接口兼容，便于替换原桌面入口。"
                               FontSize="12"
                               Foreground="{DynamicResource ColorBrushGray3}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard Margin="0,0,0,15" Title="功能">
                <StackPanel Margin="20,38,20,18">
                    <local:MyListItem Title="播放控制"
                                      Info="查看当前曲目、封面、播放进度、播放模式，并管理队列与历史。"
                                      IsHitTestVisible="False"
                                      Margin="-5,0,0,2" />
                    <local:MyListItem Title="曲库聚合"
                                      Info="按音乐来源、歌单或分组浏览后端聚合出的歌曲，并加入播放队列。"
                                      IsHitTestVisible="False"
                                      Margin="-5,0,0,2" />
                    <local:MyListItem Title="模块管理"
                                      Info="进入各音乐模块的登录、导入、同步和配置页面。"
                                      IsHitTestVisible="False"
                                      Margin="-5,0,0,2" />
                    <local:MyListItem Title="游戏集成"
                                      Info="配置游戏目录、集成 Mod 和实例连接，让游戏内可以显示与播放 OmniMix 音频。"
                                      IsHitTestVisible="False"
                                      Margin="-5,0,0,2" />
                    <local:MyListItem Title="均衡器"
                                      Info="通过控制点、预设、全局增益和软削波调整输出音色。"
                                      IsHitTestVisible="False"
                                      Margin="-5,0,0,0" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard Margin="0,0,0,15" Title="说明">
                <StackPanel Margin="25,40,25,20">
                    <TextBlock Text="当前桌面端默认请求管理员权限，用于让后端和游戏集成实例稳定通信。设置页可以调整后端路径、端口、绑定地址、托盘行为和关闭 GUI 时是否停止后端。"
                               FontSize="12"
                               Foreground="{DynamicResource ColorBrushGray3}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
