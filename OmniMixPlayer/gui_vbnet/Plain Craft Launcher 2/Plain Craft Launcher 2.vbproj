<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <SupportedOSPlatformVersion>7.0</SupportedOSPlatformVersion>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>PCL</RootNamespace>
    <AssemblyName>OmniMixPlayer.Gui.Vbnet</AssemblyName>
    <MyType>Custom</MyType>
    <StartupObject>PCL.Application</StartupObject>
    <ApplicationIcon>Images\icon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Configurations>Debug;Release;Snapshot</Configurations>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>Off</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <EnableDefaultApplicationDefinition>false</EnableDefaultApplicationDefinition>
    <EnableDefaultItems>true</EnableDefaultItems>
    <NoWarn>41999;42016;42017;42018;42019;42020;42021;42022;42032;42036;42314</NoWarn>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>SNAPSHOT=True</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DefineConstants>RELEASE=True</DefineConstants>
    <Optimize>true</Optimize>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Snapshot|AnyCPU'">
    <DefineConstants>SNAPSHOT=True</DefineConstants>
    <Optimize>true</Optimize>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

  <ItemGroup>
    <ApplicationDefinition Include="Application.xaml" />
    <Compile Remove="Controls\MySliderDot.xaml.vb" />
    <Page Remove="Controls\MySliderDot.xaml" />
    <Page Remove="Resources\Custom.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Import Include="System" />
    <Import Include="System.Collections" />
    <Import Include="System.Collections.Generic" />
    <Import Include="System.Collections.Concurrent" />
    <Import Include="System.ComponentModel" />
    <Import Include="System.IO" />
    <Import Include="System.IO.Compression" />
    <Import Include="System.Linq" />
    <Import Include="System.Net" />
    <Import Include="System.Net.Http" />
    <Import Include="System.Text" />
    <Import Include="System.Threading" />
    <Import Include="System.Threading.Tasks" />
    <Import Include="System.Windows" />
    <Import Include="System.Windows.Controls" />
    <Import Include="System.Windows.Data" />
    <Import Include="System.Windows.Documents" />
    <Import Include="System.Windows.Input" />
    <Import Include="System.Windows.Media" />
    <Import Include="System.Windows.Media.Animation" />
    <Import Include="System.Windows.Media.Effects" />
    <Import Include="System.Windows.Media.Imaging" />
    <Import Include="Microsoft.Win32" />
    <Import Include="Newtonsoft.Json.Linq" />
    <Import Include="MeloongCore" />
    <Import Include="MeloongCore.Extensions" />
    <Import Include="MeloongCore.Wpf" />
    <Import Include="MeloongCore.Wpf.Extensions" />
    <Import Include="PCLCS" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CacheCow.Client" Version="2.13.1" />
    <PackageReference Include="CacheCow.Client.FileStore" Version="2.13.1" />
    <PackageReference Include="Microsoft.AspNet.WebApi.Client" Version="6.0.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Ookii.Dialogs.Wpf" Version="5.0.1" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.0" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.0" />
    <PackageReference Include="System.Management" Version="10.0.0" />
    <PackageReference Include="System.Runtime.Caching" Version="10.0.0" />
    <PackageReference Include="System.ServiceModel.Http" Version="10.0.652802" />
    <PackageReference Include="System.Text.Encoding.CodePages" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Imazen.WebP">
      <HintPath>Resources\Imazen.WebP.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MeloongCore\Shared\MeloongCore.csproj" />
    <ProjectReference Include="..\MeloongCore\Wpf\MeloongCore.Wpf.csproj" />
    <ProjectReference Include="..\PCLCS\PCLCS.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Images\**\*" />
    <Resource Include="Resources\Font.ttf" />
  </ItemGroup>

  <Target Name="CleanSingleFilePublishArtifacts" AfterTargets="Publish" Condition="'$(PublishSingleFile)' == 'true'">
    <ItemGroup>
      <SingleFileExtraArtifacts Include="$(PublishDir)*.pdb;$(PublishDir)*.dll.config" />
    </ItemGroup>
    <Delete Files="@(SingleFileExtraArtifacts)" />
  </Target>

</Project>
