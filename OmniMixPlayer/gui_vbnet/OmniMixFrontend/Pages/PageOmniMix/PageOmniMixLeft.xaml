<local:MyPageLeft x:Class="PageOmniMixLeft"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="clr-namespace:OmniMixFrontend"
                  AnimatedControl="PanAnimated"
                  Width="300">
    <Grid x:Name="PanAnimated">
        <StackPanel x:Name="PanPlayer" Margin="18,20,18,12">
            <Border CornerRadius="10"
                    Background="{DynamicResource ColorBrushBackground}"
                    Height="228"
                    Margin="0,0,0,14"
                    ClipToBounds="True">
                <Grid>
                    <Image x:Name="ImgLeftPlaybackCover"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Visibility="Collapsed" />
                    <Path x:Name="PathLeftPlaybackCoverPlaceholder"
                          Data="M348.293565 716.53287V254.797913c0-41.672348 28.004174-78.358261 68.919652-90.37913L815.994435 40.826435c62.775652-18.610087 125.907478 26.579478 125.907478 89.933913v539.158261c8.013913 42.25113-8.94887 89.177043-47.014956 127.109565a232.848696 232.848696 0 0 1-170.785392 65.758609c-61.885217-2.938435-111.081739-33.435826-129.113043-80.050087-18.031304-46.614261-2.137043-102.177391 41.672348-145.853218a232.848696 232.848696 0 0 1 170.785391-65.80313c21.014261 1.024 40.514783 5.164522 57.878261 12.065391V233.338435c0-12.109913-10.551652-20.034783-20.569044-20.034783a24.620522 24.620522 0 0 0-5.787826 0.934957L439.785739 338.18713a19.545043 19.545043 0 0 0-14.825739 19.144348v438.984348H423.846957c11.53113 43.987478-5.164522 94.208-45.412174 134.322087a232.848696 232.848696 0 0 1-170.785392 65.758609c-61.885217-2.938435-111.081739-33.435826-129.113043-80.050087-18.031304-46.614261-2.137043-102.177391 41.672348-145.853218a232.848696 232.848696 0 0 1 170.785391-65.80313c20.791652 1.024 40.069565 5.075478 57.299478 11.842783z"
                          Stretch="Uniform"
                          Width="72"
                          Height="72"
                          Fill="{DynamicResource ColorBrushGray4}"
                          Opacity="0.75"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Grid>
            </Border>
            <Border CornerRadius="8"
                    Background="{DynamicResource ColorBrushSemiTransparent}"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="LabLeftPlaybackTrack"
                               Text="没有曲目正在播放"
                               TextWrapping="Wrap"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ColorBrush3}" />
                    <TextBlock x:Name="LabLeftPlaybackMeta"
                               Text=""
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource ColorBrushGray3}"
                               Margin="0,8,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <local:MySlider x:Name="SliderLeftProgress"
                            MaxValue="100"
                            Value="0"
                            Margin="0,0,0,4"
                            VerticalAlignment="Center" />
            <Grid Margin="0,0,0,12">
                <TextBlock x:Name="LabLeftPlaybackElapsed"
                           Text=""
                           HorizontalAlignment="Left"
                           FontSize="11"
                           Foreground="{DynamicResource ColorBrushGray4}" />
                <TextBlock x:Name="LabLeftPlaybackTotal"
                           Text=""
                           HorizontalAlignment="Right"
                           FontSize="11"
                           Foreground="{DynamicResource ColorBrushGray4}" />
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,10">
                <local:MyIconButton x:Name="BtnLeftPlaybackPrev"
                                    Width="34"
                                    Height="34"
                                    LogoScale="0.9"
                                    ToolTip="上一首"
                                    Margin="0,0,12,0" />
                <local:MyIconButton x:Name="BtnLeftPlaybackToggle"
                                    Width="42"
                                    Height="42"
                                    LogoScale="0.85"
                                    ToolTip="播放 / 暂停"
                                    Margin="0,0,12,0" />
                <local:MyIconButton x:Name="BtnLeftPlaybackNext"
                                    Width="34"
                                    Height="34"
                                    LogoScale="0.9"
                                    ToolTip="下一首" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                <local:MyIconButton x:Name="BtnLeftPlaybackMode"
                                    Width="30"
                                    Height="30"
                                    LogoScale="0.82"
                                    ToolTip="播放模式" />
            </StackPanel>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="音量"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource ColorBrush2}"
                           Margin="0,0,10,0" />
                <local:MySlider x:Name="SliderLeftVolume"
                                Grid.Column="1"
                                MaxValue="100"
                                Value="100"
                                VerticalAlignment="Center" />
                <TextBlock x:Name="LabLeftPlaybackVolume"
                           Grid.Column="2"
                           Text="100%"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource ColorBrushGray3}"
                           Margin="10,0,0,0" />
            </Grid>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="延迟"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource ColorBrush2}"
                           Margin="0,0,10,0" />
                <local:MySlider x:Name="SliderLeftLatency"
                                Grid.Column="1"
                                MaxValue="1000"
                                Value="50"
                                VerticalAlignment="Center" />
                <TextBlock x:Name="LabLeftPlaybackLatency"
                           Grid.Column="2"
                           Text="0.05s"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource ColorBrushGray3}"
                           Margin="10,0,0,0" />
            </Grid>
        </StackPanel>

        <local:MyScrollViewer x:Name="PanNavScroll"
                              Visibility="Collapsed"
                              PanningMode="VerticalOnly"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
            Style="{StaticResource ScrollViewerFullMargin}">
            <StackPanel x:Name="PanNavItems" Margin="0,12,0,0">
                <StackPanel x:Name="PanLibraryNav" Visibility="Collapsed">
                </StackPanel>

                <StackPanel x:Name="PanModuleNav" Visibility="Collapsed">
                    <local:MyListItem x:Name="ItemModuleLaunchpad"
                                      Checked="True"
                                      Type="RadioBox"
                                      Tag="launchpad"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="启动台"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemModuleMod"
                                      Type="RadioBox"
                                      Tag="mod"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="Mod"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemModuleGameIntegration"
                                      Type="RadioBox"
                                      Tag="game"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="游戏集成"
                                      IsScaleAnimationEnabled="False" />
                </StackPanel>

                <StackPanel x:Name="PanSettingsNav" Visibility="Collapsed">
                    <local:MyListItem x:Name="ItemSettingsConfig"
                                      Checked="True"
                                      Type="RadioBox"
                                      Tag="config"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="后端配置"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemSettingsPersonalization"
                                      Type="RadioBox"
                                      Tag="personalization"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="个性化"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemSettingsMaintenance"
                                      Type="RadioBox"
                                      Tag="maintenance"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="初始化与缓存"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemSettingsInstances"
                                      Type="RadioBox"
                                      Tag="instances"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="播放实例"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemSettingsEqualizer"
                                      Type="RadioBox"
                                      Tag="equalizer"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="均衡器"
                                      IsScaleAnimationEnabled="False" />
                    <local:MyListItem x:Name="ItemSettingsArchives"
                                      Type="RadioBox"
                                      Tag="archives"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="归档"
                                      IsScaleAnimationEnabled="False" />
                </StackPanel>

                <StackPanel x:Name="PanAboutNav" Visibility="Collapsed">
                    <local:MyListItem x:Name="ItemAboutOverview"
                                      Checked="True"
                                      Type="RadioBox"
                                      Tag="overview"
                                      MinPaddingRight="35"
                                      Height="36"
                                      VerticalAlignment="Top"
                                      Title="关于"
                                      IsScaleAnimationEnabled="False" />
                </StackPanel>
            </StackPanel>
        </local:MyScrollViewer>
    </Grid>
</local:MyPageLeft>
