<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- GitHub Packages — 私有包 ChillPatcher.GameRefs -->
    <!-- 本地开发: setx PACKAGES_PAT ghp_xxxx -->
    <!-- CI: secrets.PACKAGES_PAT 自动注入 -->
    <add key="github-private" value="https://nuget.pkg.github.com/BeyondtheApex/index.json" />
  </packageSources>

  <!-- 环境变量认证：PACKAGES_PAT -->
  <packageSourceCredentials>
    <github-private>
      <add key="Username" value="BeyondtheApex" />
      <add key="ClearTextPassword" value="%PACKAGES_PAT%" />
    </github-private>
  </packageSourceCredentials>
</configuration>
